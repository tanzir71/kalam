{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kalam",
  "version": "0.1.0",
  "identifier": "app.kalam.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kalam",
        "width": 1200,
        "height": 820,
        "minWidth": 880,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
