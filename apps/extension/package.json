{
  "name": "@kalam/extension",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "pnpm --filter @kalam/ui build && pnpm build:chrome && pnpm build:firefox",
    "build:chrome": "vite build --mode chrome && node scripts/render-static-gallery.mjs chrome",
    "build:firefox": "vite build --mode firefox && node scripts/render-static-gallery.mjs firefox",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@kalam/core": "workspace:*",
    "@kalam/ui": "workspace:*",
    "@vitejs/plugin-react": "latest",
    "vite": "8.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "webextension-polyfill": "0.12.0"
  },
  "devDependencies": {
    "@types/chrome": "0.1.34",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "vitest": "4.0.14"
  }
}
